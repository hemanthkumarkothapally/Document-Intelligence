<core:FragmentDefinition xmlns:unified="sap.ui.unified"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog title="Upload File to Extract Data">
        <content>
            <unified:FileUploader valueState="None" id="idFileUploader" class="sapUiSmallMargin" fileType="pdf" name="myFileUpload" tooltip="Upload your file" change=".onFileChange"></unified:FileUploader>
        </content>
        <beginButton>
            <Button text="Cancel" press=".onCloseUploadDialogPress" />

        </beginButton>

        <endButton>
            <Button text="Done" press=".onFileUploadPress"/>

        </endButton>

    </Dialog>
</core:FragmentDefinition>