<mvc:View controllerName="documentintelligenceui.controller.DocumentsList"
    xmlns:odata="sap.ui.comp.odata"
    xmlns:filterbar="sap.ui.comp.filterbar"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <f:DynamicPage>
        <f:title />
        <f:header>
            <f:DynamicPageHeader>
                <f:content>

                    <filterbar:FilterBar id="idFilterBar" useToolbar="false" search=".onGoBtnPress">

                        <filterbar:filterGroupItems>

                            <!-- 🔹 ID Filter -->
                            <filterbar:FilterGroupItem label="{i18n>id}" name="ID" groupName="group1" visibleInFilterBar="true">

                                <filterbar:control>
                                    <Input placeholder="Enter ID"/>
                                </filterbar:control>

                            </filterbar:FilterGroupItem>

                            <!-- 🔹 File Name -->
                            <filterbar:FilterGroupItem label="{i18n>fileName}" name="fileName" groupName="group1" visibleInFilterBar="true">

                                <filterbar:control>
                                    <Input placeholder="Enter File Name"/>
                                </filterbar:control>

                            </filterbar:FilterGroupItem>

                            <!-- 🔹 Uploaded By -->
                            <filterbar:FilterGroupItem label="{i18n>uploadedBy}" name="uploadedBy" groupName="group1" visibleInFilterBar="true">

                                <filterbar:control>
                                    <Input placeholder="Enter User"/>
                                </filterbar:control>

                            </filterbar:FilterGroupItem>

                            <!-- 🔹 Status Dropdown -->
                            <filterbar:FilterGroupItem label="{i18n>status}" name="status" groupName="group1" visibleInFilterBar="true">

                                <filterbar:control>
                                    <ComboBox>
                                        <core:Item key="Pending" text="Pending"/>
                                        <core:Item key="Done" text="Done"/>
                                        <core:Item key="Failed" text="Failed"/>
                                    </ComboBox>
                                </filterbar:control>

                            </filterbar:FilterGroupItem>

                        </filterbar:filterGroupItems>

                    </filterbar:FilterBar>

                </f:content>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <Table id="documentsTable" items="{/Documents}" growing="true" growingThreshold="10">
                <headerToolbar>
                    <tnt:ToolHeader>
                        <Title text="Documents ({= ${/Documents/$count}})" />
                        <ToolbarSpacer />
                        <Button text="{i18n>uploadBtnText}" type="Accept" press=".onDocumentUploadBtnPress" />
                    </tnt:ToolHeader>
                </headerToolbar>
                <columns >
                    <Column>
                        <Text text="{i18n>fileName}"/>
                    </Column>

                    <Column>
                        <Text text="{i18n>uploadedBy}"/>
                    </Column>

                    <Column>
                        <Text text="{i18n>uploadedAt}"/>
                    </Column>

                    <Column>
                        <Text text="{i18n>status}"/>
                    </Column>

                    <Column>
                        <Text text="{i18n>rawText}"/>
                    </Column>


                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onNavigationPress">
                        <cells>
                            <Text text="{fileName}"/>
                            <Text text="{uploadedBy}"/>
                            <Text text="{uploadedAt}"/>
                            <ObjectStatus text="{status}"/>
                            <Text text="{rawText}" wrapping="false"/>
                        </cells>

                    </ColumnListItem>
                </items>

            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>