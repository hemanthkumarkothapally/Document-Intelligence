<mvc:View xmlns:form="sap.ui.layout.form" controllerName="documentintelligenceui.controller.DocumentDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap">

    <uxap:ObjectPageLayout id="objectPage">

        <!-- 🔷 HEADER -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:heading>
                    <Title text="{fileName}" />
                </uxap:heading>

                <uxap:actions>
                    <Button text="Edit" type="Attention" visible="{= !${EditModel>/isEdit} }" press=".onEditPress"></Button>
                    <Button text="Save" type="Emphasized" visible="{= ${EditModel>/isEdit} }" press=".onSavePress"/>
                    <Button text="Cancel" type="Negative" visible="{= ${EditModel>/isEdit} }" press=".onCancelEditPress"></Button>

                </uxap:actions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!-- 🔷 SECTIONS -->
        <uxap:sections>

            <!-- 📄 DOCUMENT SECTION -->
            <uxap:ObjectPageSection title="Document">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <form:SimpleForm layout="ColumnLayout" columnsXL="2" columnsL="2" columnsM="1">
                            <Label text="File Name"></Label>
                            <Text text="{fileName}"></Text>
                            <!-- <Input value="{fileName}" placeholder="File Name"/> -->
                            <Label text="Uploaded By"></Label>
                            <Text text="{uploadedBy}"></Text>
                            <!-- <Input value="{uploadedBy}" placeholder="Uploaded By"/> -->
                            <Label text="Uploaded On"></Label>
                            <Text text="{uploadedAt}"></Text>
                            <!-- <DatePicker value="{uploadedAt}" /> -->
                            <Label text="Status"></Label>
                            <Text text="{status}"></Text>
                            <!-- <Input value="{status}" /> -->
                            <Label text="Raw Text"></Label>

                            <TextArea value="{rawText}" enabled="false" rows="5"/>
                        </form:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- INVOICE SECTION -->
            <uxap:ObjectPageSection title="Invoice">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <form:SimpleForm id="idDisplayInvoiceForm" layout="ColumnLayout" columnsXL="2" columnsL="2" columnsM="1" visible="{= !${EditModel>/isEdit} }">
                            <Label text="Invoice Number"></Label>
                            <Text text="{invoice/invoiceNumber}" visible="{= !${EditModel>/isEdit} }"></Text>
                            <Label text="Vendor Name"></Label>
                            <Text text="{invoice/vendorName}" visible="{= !${EditModel>/isEdit} }"></Text>
                            <Label text="Invoice Date"></Label>
                            <Text text="{invoice/invoiceDate}" visible="{= !${EditModel>/isEdit} }"></Text>
                            <Label text="Total Amount"></Label>
                            <Text text="{invoice/totalAmount}" visible="{= !${EditModel>/isEdit} }"></Text>
                            <Label text="Currency"></Label>
                            <Text text="{invoice/currency}" visible="{= !${EditModel>/isEdit} }"></Text>
                        </form:SimpleForm>
                        <form:SimpleForm id="idEditInvoiceForm" layout="ColumnLayout" columnsXL="2" columnsL="2" columnsM="1" visible="{= ${EditModel>/isEdit} }">
                            <Label text="Invoice Number"></Label>
                            <Input value="{invoice/invoiceNumber}" placeholder="Invoice Number" visible="{= ${EditModel>/isEdit} }"/>
                            <Label text="Vendor Name"></Label>
                            <Input value="{invoice/vendorName}" placeholder="Vendor Name" visible="{= ${EditModel>/isEdit} }"/>
                            <Label text="Invoice Date"></Label>
                            <DatePicker value="{invoice/invoiceDate}" visible="{= ${EditModel>/isEdit} }" />
                            <Label text="Total Amount"></Label>
                            <Input value="{invoice/totalAmount}" visible="{= ${EditModel>/isEdit} }" />
                            <Label text="Currency"></Label>
                            <Input value="{invoice/currency}" visible="{= ${EditModel>/isEdit} }"/>
                        </form:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- LINE ITEMS SECTION -->
            <uxap:ObjectPageSection title="Line Items">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>

                        <Table items="{invoice/lineItems}">
                            <columns>
                                <Column>
                                    <Text text="Description"/>
                                </Column>
                                <Column>
                                    <Text text="Qty"/>
                                </Column>
                                <Column>
                                    <Text text="Unit Price"/>
                                </Column>
                                <Column>
                                    <Text text="Total"/>
                                </Column>
                            </columns>

                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <HBox>
                                            <Text text="{description}" visible="{= !${EditModel>/isEdit} }"/>
                                            <Input value="{description}" visible="{= ${EditModel>/isEdit} }"/>
                                        </HBox>
                                        <HBox>
                                            <Text text="{quantity}" visible="{= !${EditModel>/isEdit} }"/>
                                            <Input value="{quantity}" visible="{= ${EditModel>/isEdit} }"/>
                                        </HBox>
                                        <HBox>
                                            <Text text="{unitPrice}" visible="{= !${EditModel>/isEdit} }"/>
                                            <Input value="{unitPrice}" visible="{= ${EditModel>/isEdit} }"/>
                                        </HBox>
                                        <HBox >
                                            <Text text="{lineTotal}" visible="{= !${EditModel>/isEdit} }"/>
                                            <Input value="{lineTotal}" visible="{= ${EditModel>/isEdit} }"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- AUDIT LOGS SECTION -->
            <uxap:ObjectPageSection title="Audit Logs">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>

                        <Table items="{auditLogs}">
                            <columns>
                                <Column>
                                    <Text text="Action"/>
                                </Column>
                                <Column>
                                    <Text text="User"/>
                                </Column>
                                <Column>
                                    <Text text="Time"/>
                                </Column>
                                <Column>
                                    <Text text="Details"/>
                                </Column>
                            </columns>

                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{action}"/>
                                        <Text text="{performedBy}"/>
                                        <Text text="{performedAt}"/>
                                        <Text text="{path: 'details',formatter: '.formatAuditDetails'}" wrapping="true"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

        </uxap:sections>

    </uxap:ObjectPageLayout>
</mvc:View>